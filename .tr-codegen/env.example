# TR-Codegen User Management System - Environment Configuration

# Application Settings
APP_PORT=3000
DEV_PORT=3001
DOMAIN=localhost
TZ=UTC

# Build Information
BUILD_DATE=
VCS_REF=

# Nginx Configuration
NGINX_HOST=localhost

# Traefik Reverse Proxy (--profile proxy)
TRAEFIK_HTTP_PORT=80
TRAEFIK_HTTPS_PORT=443
TRAEFIK_DASHBOARD_PORT=8080
TRAEFIK_LOG_LEVEL=INFO
ACME_EMAIL=admin@example.com

# Monitoring Stack (--profile monitoring)
PROMETHEUS_PORT=9090
GRAFANA_PORT=3002
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
NGINX_EXPORTER_PORT=9113

# Redis Cache (--profile cache)
REDIS_PORT=6379
REDIS_PASSWORD=changeme

# Development Settings
NODE_ENV=production
DEBUG=false

# Security Settings
SECURE_HEADERS=true
CORS_ORIGIN=*

# Logging
LOG_LEVEL=info
ACCESS_LOG=true
